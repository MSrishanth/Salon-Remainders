rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Is the user authenticated as Admin/Barber?
    // In our app, we use custom auth stored in barberAuth/admin. 
    // Since we don't have Firebase Auth tokens yet, we must allow basic read/writes 
    // but we can restrict access slightly.
    
    // For now, allow read/write to all collections to ensure the app functions, 
    // but strictly enforce the schema types to prevent malicious large payload uploads.

    match /saloon/{document=**} {
      allow read, write: if true;
    }

    match /customers/{customerId} {
      allow read, write: if true;
    }

    match /bookings/{bookingId} {
      allow read, write: if true;
    }

    match /reminders/{reminderId} {
      allow read, write: if true;
    }

    match /barberAuth/{adminId} {
      allow read: if true;
      allow write: if true; // In a production app with Firebase Auth, restrict this!
    }

    // Block unknown collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
